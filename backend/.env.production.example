# ---------------------------
# VidyaVerse Production .env
# ---------------------------

# Database
MONGODB_URL=<your-production-mongodb-url>
MONGODB_DB_NAME=vidyaverse

# Security / Runtime
ENVIRONMENT=production
SECRET_KEY=<generate-64-byte-hex-or-base64-secret>
AUTH_SESSION_COOKIE_ENABLED=true
AUTH_SESSION_COOKIE_NAME=vidyaverse_session
AUTH_SESSION_COOKIE_SECURE=true
AUTH_SESSION_COOKIE_SAMESITE=lax
AUTH_SESSION_COOKIE_PATH=/
AUTH_SESSION_COOKIE_DOMAIN=
AUTH_SESSION_COOKIE_MAX_AGE_SECONDS=86400
AUTH_COOKIE_ONLY_MODE=true
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_EMAIL=ghoshankan005@gmail.com
ADMIN_BOOTSTRAP_PASSWORD=<set-in-secrets-manager>
ADMIN_TOTP_SECRET=<base32-secret-from-authenticator>
ADMIN_TOTP_ISSUER=Vidyaverse
ADMIN_TOTP_DIGITS=6
ADMIN_TOTP_PERIOD_SECONDS=30
ADMIN_TOTP_WINDOW_STEPS=1
CSRF_PROTECTION_ENABLED=true
CSRF_ENFORCE_ON_AUTH_COOKIE=true
CSRF_TRUSTED_ORIGINS=["https://web.test","https://your-frontend-domain.com"]
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP_ENABLED=true
SECURITY_CSP_REPORT_ONLY=false
SECURITY_CSP_ENFORCE_STRICT_IN_PRODUCTION=true
# Optional override (otherwise backend default is used):
# SECURITY_CSP_VALUE=default-src 'self'; ...

# Redis (managed Redis strongly recommended)
REDIS_URL=redis://:<password>@<host>:6379/0
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# API Host/CORS hardening
BACKEND_CORS_ORIGINS=["https://web.test","https://your-frontend-domain.com"]
ALLOWED_HOSTS=["api.test","your-api-domain.com"]

# LLM endpoint (OpenAI-compatible)
# NVIDIA example:
# LLM_API_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=deepseek-ai/deepseek-v3.2
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional separate judge model endpoint/credentials
# NVIDIA judge example:
# LLM_JUDGE_API_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_JUDGE_MODEL=deepseek-ai/deepseek-v3.1-terminus
LLM_JUDGE_ENABLED=false
LLM_JUDGE_API_BASE_URL=
LLM_JUDGE_API_KEY=
LLM_JUDGE_MODEL=
LLM_JUDGE_MIN_SCORE=0.55

# Embeddings: sentence-transformers primary + OpenAI-compatible fallback
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_API_KEY=
OPENAI_API_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_HEALTH_ENFORCE_IN_PRODUCTION=true
EMBEDDING_HEALTH_FAIL_ON_HASH_FALLBACK=true

# Jobs / scraping
SCRAPER_AUTORUN_ENABLED=true
SCRAPER_INTERVAL_MINUTES=30
SCRAPER_MAX_STALENESS_MINUTES=30

# Metrics and rate limits
METRICS_ENABLED=true
METRICS_REQUIRE_AUTH=true
RATE_LIMIT_ENABLED=true

# Experiment guardrails
EXPERIMENT_AUTO_PAUSE_ON_GUARDRAIL_FAIL=true
EXPERIMENT_SRM_P_VALUE_THRESHOLD=0.01
EXPERIMENT_SIGNIFICANCE_ALPHA=0.05
EXPERIMENT_GUARDRAIL_MIN_IMPRESSIONS_PER_VARIANT=200

# OTP
OTP_ALLOW_DEBUG_FALLBACK=false
OTP_SEND_COOLDOWN_SECONDS=60

# Ask AI reliability
# Low-latency NVIDIA defaults for interactive Ask AI:
# RAG_LLM_MODEL=meta/llama-3.1-8b-instruct
# RAG_JUDGE_MODEL=meta/llama-3.2-3b-instruct
RAG_LLM_MODEL=
RAG_JUDGE_MODEL=
RAG_WARMUP_ON_STARTUP=true
RAG_WARMUP_TIMEOUT_SECONDS=120
RAG_REQUEST_TIMEOUT_SECONDS=25
RAG_RETRIEVAL_TIMEOUT_SECONDS=45
RAG_LLM_TIMEOUT_SECONDS=15
RAG_JUDGE_TIMEOUT_SECONDS=8
ASSISTANT_CHAT_MEMORY_ENABLED=true
ASSISTANT_CHAT_MEMORY_MAX_TURNS=12
ASSISTANT_CHAT_RAG_AUTO_ROUTE_ENABLED=true
ASSISTANT_CHAT_SURFACE_DEFAULT=global_chat
ASSISTANT_CHAT_SUMMARY_ENABLED=true
ASSISTANT_CHAT_SUMMARY_TRIGGER_TURNS=16
ASSISTANT_CHAT_SUMMARY_RETAIN_TURNS=8
ASSISTANT_CHAT_PROMPT_VERSION=assistant.v2
ASSISTANT_CHAT_TOOLS_ENABLED=true

# Warehouse / online features
ANALYTICS_WAREHOUSE_EXPORT_ENABLED=true
ANALYTICS_WAREHOUSE_EXPORT_ROOT=backend/storage/warehouse
ANALYTICS_WAREHOUSE_DUCKDB_PATH=backend/storage/warehouse/warehouse.duckdb
ANALYTICS_WAREHOUSE_EXPORT_FORMAT=duckdb_parquet
ANALYTICS_WAREHOUSE_SQL_MODELS_DIR=backend/warehouse/models
ANALYTICS_WAREHOUSE_CLICKHOUSE_ENABLED=true
ANALYTICS_WAREHOUSE_CLICKHOUSE_HOST=clickhouse
ANALYTICS_WAREHOUSE_CLICKHOUSE_PORT=8123
ANALYTICS_WAREHOUSE_CLICKHOUSE_DATABASE=vidyaverse
ANALYTICS_WAREHOUSE_CLICKHOUSE_USERNAME=vidyaverse
ANALYTICS_WAREHOUSE_CLICKHOUSE_PASSWORD=<clickhouse-password>
ANALYTICS_WAREHOUSE_CLICKHOUSE_SECURE=false
ANALYTICS_WAREHOUSE_CLICKHOUSE_TABLE_PREFIX=mart_
ANALYTICS_WAREHOUSE_REQUIRED_MARTS=["mart_daily_metrics","mart_funnel_metrics","mart_cohort_metrics","mart_feature_freshness","mart_parity_scorecard","mart_training_dataset","mart_ranking_slice_metrics","mart_metadata"]
ANALYTICS_WAREHOUSE_MAX_STALENESS_MINUTES=180
ANALYTICS_WAREHOUSE_ENFORCE_CLICKHOUSE_IN_PRODUCTION=true
ANALYTICS_WAREHOUSE_ENFORCE_FRESHNESS_IN_PRODUCTION=true
ANALYTICS_WAREHOUSE_BI_TOOL_URL=https://your-metabase-or-evidence-domain.com
ANALYTICS_BI_TOOL_URL=https://your-metabase-or-evidence-domain.com
ONLINE_FEATURES_PUBLISH_ENABLED=true
ONLINE_FEATURES_KEY_PREFIX=vidyaverse:features
ONLINE_FEATURES_TTL_SECONDS=1209600

# MLOps alerts + incident loop
MLOPS_ALERTS_ENABLED=true
MLOPS_ALERT_WEBHOOK_URL=
MLOPS_ALERT_SLACK_WEBHOOK_URL=
MLOPS_ALERT_PAGERDUTY_ROUTING_KEY=
MLOPS_ALERT_PAGERDUTY_SEVERITY=error
MLOPS_INCIDENT_AUTO_CREATE=true
MLOPS_INCIDENT_DEFAULT_OWNER=
MLOPS_INCIDENT_REVIEW_DUE_HOURS=24
MLOPS_INCIDENT_BREACH_SLA_HOURS=72
MLOPS_ENFORCE_LIVE_ALERT_CHANNELS_IN_PRODUCTION=true
MLOPS_ENFORCE_OWNER_IN_PRODUCTION=true

# Offline/online parity gates for auto-activation
MLOPS_PARITY_ENABLED=true
MLOPS_PARITY_MIN_REAL_IMPRESSIONS_PER_MODE=200
MLOPS_PARITY_MIN_REAL_REQUESTS_PER_MODE=100
MLOPS_PARITY_MAX_CTR_REGRESSION=0.0
MLOPS_PARITY_MAX_APPLY_RATE_REGRESSION=0.0
MLOPS_PARITY_MIN_OFFLINE_AUC_GAIN_FOR_ONLINE_GATES=0.0

# Learned-ranker rollout controls
LEARNED_RANKER_ENABLED=true
LEARNED_RANKER_MODEL_PATH=/app/models/learned_ranker.lgb.txt
LEARNED_RANKER_ARTIFACT_URI=file:///app/models/learned_ranker.lgb.txt
LEARNED_RANKER_ARTIFACT_CHECKSUM_SHA256=
LEARNED_RANKER_REQUIRE_ARTIFACT_IN_PRODUCTION=true
LEARNED_RANKER_REQUIRE_LOADED_IN_PRODUCTION=true
MODEL_REGISTRY_REQUIRE_APPROVED_FOR_ACTIVATION=true
LEARNED_RANKER_SHADOW_ENABLED=true
LEARNED_RANKER_SHADOW_SAMPLE_RATE=1.0
LEARNED_RANKER_SHADOW_MAX_CANDIDATES=100
LEARNED_RANKER_STAGED_ROLLOUT_ENABLED=true
LEARNED_RANKER_STAGED_ROLLOUT_PERCENT=10
LEARNED_RANKER_STAGED_BASELINE_MODE=semantic
LEARNED_RANKER_ROLLOUT_EXPERIMENT_KEY=learned_ranker_rollout
LEARNED_RANKER_ROLLBACK_ON_GUARDRAIL_FAILURE=true
MLOPS_MODEL_ARTIFACT_CACHE_DIR=/app/storage/model_artifacts
MLOPS_MODEL_ARTIFACT_S3_ENDPOINT_URL=
MLOPS_MODEL_ARTIFACT_S3_REGION=
MLOPS_MODEL_ARTIFACT_S3_ACCESS_KEY_ID=
MLOPS_MODEL_ARTIFACT_S3_SECRET_ACCESS_KEY=

# Security reporting
SECURITY_CSP_REPORT_URI=/api/v1/security/csp-report

# SMTP (required for OTP delivery)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USE_TLS=false
SMTP_TLS_VALIDATE_CERTS=true
# Optional custom CA bundle path. Leave empty to use certifi defaults.
SMTP_TLS_CA_FILE=
SMTP_REQUIRE_AUTH=true
SMTP_USER=<smtp-user>
SMTP_PASSWORD=<smtp-app-password>
SMTP_FROM_EMAIL=<verified-sender@example.com>
SMTP_FROM_NAME=VidyaVerse

# OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-api-domain.com/api/v1/auth/oauth/google/callback
LINKEDIN_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
FRONTEND_OAUTH_SUCCESS_URL=https://your-frontend-domain.com/auth/callback
FRONTEND_OAUTH_FAILURE_URL=https://your-frontend-domain.com/login
