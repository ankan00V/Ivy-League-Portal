# Core DB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=vidyaverse

# Runtime
ENVIRONMENT=local
SECRET_KEY=replace-with-long-random-secret

# Redis
REDIS_URL=redis://localhost:6379/0
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Embeddings (sentence-transformers primary, OpenAI-compatible fallback)
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_API_KEY=
OPENAI_API_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM endpoint (OpenAI-compatible). If set, these override OPENROUTER_* in services.
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional dedicated judge endpoint/credentials (falls back to LLM_* if unset)
LLM_JUDGE_ENABLED=false
LLM_JUDGE_API_BASE_URL=
LLM_JUDGE_API_KEY=
LLM_JUDGE_MODEL=
LLM_JUDGE_MIN_SCORE=0.55

# Legacy OpenRouter compatibility
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

# Networking
BACKEND_CORS_ORIGINS=["http://localhost:3000","https://web.test"]
ALLOWED_HOSTS=["localhost","127.0.0.1","web.test","api.test"]

# Scraper scheduler
SCRAPER_AUTORUN_ENABLED=true
SCRAPER_INTERVAL_MINUTES=30
SCRAPER_MAX_STALENESS_MINUTES=30

# Experiment guardrails
EXPERIMENT_AUTO_PAUSE_ON_GUARDRAIL_FAIL=true
EXPERIMENT_SRM_P_VALUE_THRESHOLD=0.01
EXPERIMENT_SIGNIFICANCE_ALPHA=0.05
EXPERIMENT_GUARDRAIL_MIN_IMPRESSIONS_PER_VARIANT=50

# OTP (local debug fallback only)
OTP_ALLOW_DEBUG_FALLBACK=true

# OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/oauth/google/callback
LINKEDIN_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
FRONTEND_OAUTH_SUCCESS_URL=http://localhost:3000/auth/callback
FRONTEND_OAUTH_FAILURE_URL=http://localhost:3000/login
