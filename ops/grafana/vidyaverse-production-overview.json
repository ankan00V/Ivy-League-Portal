{
  "title": "VidyaVerse Data Science Operating Loop",
  "tags": ["vidyaverse", "mlops", "datascience", "gates"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Feature Freshness (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "max(ds_feature_freshness_seconds)",
          "legendFormat": "feature_store",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Opportunity Freshness SLA",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "max(opportunity_freshness_sla_breached)",
          "legendFormat": "sla_breach",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Model Input Drift",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "max by (metric) (ds_model_input_drift_value{metric=~\"query_bucket_psi|max_feature_mean_z|alert\"})",
          "legendFormat": "{{metric}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Parity CTR / Apply Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "max by (mode, metric) (ds_parity_scorecard_value{metric=~\"ctr|apply_rate\"})",
          "legendFormat": "{{mode}} {{metric}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Ranker Slice CTR",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "max by (slice_type, slice_name) (ds_ranking_slice_rate{metric=\"ctr\"})",
          "legendFormat": "{{slice_type}}/{{slice_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Ranker Slice Apply Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "max by (slice_type, slice_name) (ds_ranking_slice_rate{metric=\"apply_rate\"})",
          "legendFormat": "{{slice_type}}/{{slice_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Assistant Failure / Hallucination / Citation Quality",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "max by (metric, prompt_version, route) (ds_assistant_quality_value{metric=~\"failure_rate|hallucination_rate|citation_correctness\"})",
          "legendFormat": "{{metric}} {{prompt_version}} {{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Assistant Route Counts",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "max by (route) (ds_assistant_quality_value{metric=\"route_count\"})",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Model Promotion State",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "max by (model_name, status, reason) (ds_model_promotion_info)",
          "legendFormat": "{{status}} {{model_name}} {{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Warehouse Export Errors",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "increase(warehouse_exports_total{status=\"error\"}[30m])",
          "legendFormat": "{{format}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Ranking Request Latency p95 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, request_kind) (rate(ranking_request_latency_ms_bucket{traffic_type=\"real\"}[5m])))",
          "legendFormat": "{{request_kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" }
}
