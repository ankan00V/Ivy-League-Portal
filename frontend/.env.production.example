# VidyaVerse frontend production environment.
# Values here must point at deployed services, not local tunnels or Docker.

NEXT_PUBLIC_API_BASE_URL=https://your-api-domain.com
BACKEND_INTERNAL_URL=https://your-api-domain.com

NEXT_PUBLIC_ADMIN_LOGIN_PATH=/control/auth
NEXT_PUBLIC_ADMIN_DASHBOARD_PATH=/control/ops

NEXT_PUBLIC_TURNSTILE_SITE_KEY=<cloudflare-turnstile-site-key>
NEXT_PUBLIC_API_ORIGIN=https://your-api-domain.com
NEXT_PUBLIC_CSP_CONNECT_SRC_EXTRA=https://your-api-domain.com
NEXT_PUBLIC_CSP_REPORT_URI=/api/v1/security/csp-report
NEXT_PUBLIC_CSP_ENABLE_TRUSTED_TYPES=1
NEXT_PUBLIC_CSP_STRICT_DYNAMIC=1
